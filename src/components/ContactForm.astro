---

---

<form id="contact-form" class="flex flex-col w-full gap-8.5">
  <input
    type="text"
    name="name"
    placeholder="NAME"
    class="font-light text-xs h-8 border-b focus:outline-none"
  />
  <input
    type="email"
    name="email"
    placeholder="EMAIL"
    class="font-light text-xs h-8 border-b focus:outline-none"
  />

  <textarea
    name="message"
    placeholder="Your message..."
    class="font-light text-sm min-h-20 border-b mb-4 focus:outline-none"
  ></textarea>
  <button
    type="submit"
    class="rounded-lg py-1 w-full md:w-37.5 cursor-pointer border-[0.1px] border-primary-gray hover:bg-primary-black/70 hover:border-primary-white transition duration-200"
  >
    Send
  </button>
</form>
